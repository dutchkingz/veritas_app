<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title>VERITAS // WAR ROOM</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="VERITAS — Real-Time Intelligence Platform for Narrative Warfare">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="veritas-body" data-controller="screensaver<%= ' breaking-alert' if user_signed_in? %>" data-screensaver-image="<%= asset_path('warroom_screensaver.png') %>">


    <!-- Top Navigation Bar -->
    <%= render "shared/banner" %>

    <!-- Flash Messages -->
    <% if notice %>
      <div class="veritas-flash veritas-flash-success"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="veritas-flash veritas-flash-danger"><%= alert %></div>
    <% end %>

    <!-- Main Content -->
    <%= yield %>

    <!-- Global RAG Chat Widget -->
    <%= render "shared/chat_interface" %>

    <!-- Model Settings Modal (signed-in users only) -->
    <% if user_signed_in? %>
      <%= render "model_configs/modal" %>
    <% end %>

    <!-- Voice Orb (dashboard only) -->
    <% if controller_name == "pages" && action_name == "home" %>
      <%= render "shared/voice_orb" %>
    <% end %>
  </body>
</html>
