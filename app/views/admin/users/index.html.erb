<%# app/views/admin/users/index.html.erb %>
<%# User Access Control Panel — Admin only %>

<div class="min-h-screen bg-gray-950 text-gray-100 p-8">

  <div class="max-w-5xl mx-auto">

    <%# Header %>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-cyan-400 tracking-widest uppercase">
        User Access Control
      </h1>
      <p class="text-gray-400 mt-1">Manage roles and permissions for all VERITAS personnel.</p>
    </div>

    <%# Flash messages %>
    <% if notice %>
      <div class="mb-4 px-4 py-3 rounded bg-green-900 border border-green-500 text-green-300">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="mb-4 px-4 py-3 rounded bg-red-900 border border-red-500 text-red-300">
        <%= alert %>
      </div>
    <% end %>

    <%# Users Table %>
    <div class="overflow-x-auto rounded-lg border border-gray-700">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-800 text-cyan-400 uppercase text-xs tracking-wider">
          <tr>
            <th class="px-6 py-4">ID</th>
            <th class="px-6 py-4">Email</th>
            <th class="px-6 py-4">Role</th>
            <th class="px-6 py-4">Joined</th>
            <th class="px-6 py-4">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-700">
          <% @users.each do |user| %>
            <tr class="bg-gray-900 hover:bg-gray-800 transition">
              <td class="px-6 py-4 text-gray-400"><%= user.id %></td>
              <td class="px-6 py-4"><%= user.email %></td>

              <%# Role badge with colour coding %>
              <td class="px-6 py-4">
                <span class="px-2 py-1 rounded text-xs font-bold uppercase
                  <%= user.role == 'admin' ? 'bg-red-900 text-red-300' :
                      user.role == 'user'  ? 'bg-cyan-900 text-cyan-300' :
                                             'bg-gray-700 text-gray-400' %>">
                  <%= user.role %>
                </span>
              </td>

              <td class="px-6 py-4 text-gray-400">
                <%= user.created_at.strftime("%d %b %Y") %>
              </td>

              <%# Actions — only render if policy allows %>
              <td class="px-6 py-4 flex gap-3">
                <% if policy(user).edit? %>
                  <%= link_to "Edit Role",
                        edit_admin_user_path(user),
                        class: "text-cyan-400 hover:text-cyan-200 underline text-xs" %>
                <% end %>

                <% if policy(user).destroy? %>
                  <%= link_to "Remove",
                        admin_user_path(user),
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "Are you sure you want to remove #{user.email}?"
                        },
                        class: "text-red-400 hover:text-red-200 underline text-xs" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>
